{
    "name": "symfinity/ux-blocks-form",
    "description": "Form domain Twig components — labels, inputs, compounds, and native interaction CSS",
    "type": "symfony-bundle",
    "license": "MIT",
    "homepage": "https://github.com/symfinity/ux-blocks-form",
    "support": {
        "issues": "https://github.com/symfinity/ux-blocks-form/issues",
        "source": "https://github.com/symfinity/ux-blocks-form"
    },
    "authors": [
        {
            "name": "Symfinity",
            "email": "dev@symfinity.net",
            "homepage": "https://symfinity.net/"
        }
    ],
    "keywords": [
        "symfony",
        "symfony-bundle",
        "symfony-ux",
        "twig-components",
        "ux-blocks",
        "forms",
        "design-system"
    ],
    "require": {
        "php": ">=8.2",
        "symfinity/ux-blocks": "^0.1",
        "symfinity/ux-blocks-core": "^0.1",
        "symfony/asset-mapper": "^7.4||^8.0",
        "symfony/config": "^7.4||^8.0",
        "symfony/dependency-injection": "^7.4||^8.0",
        "symfony/framework-bundle": "^7.4",
        "symfony/http-foundation": "^7.4||^8.0",
        "symfony/http-kernel": "^7.4||^8.0",
        "symfony/stimulus-bundle": "^2.0|^3.0",
        "symfony/twig-bundle": "^7.4||^8.0",
        "symfony/ux-twig-component": "^2.0|^3.0",
        "symfony/yaml": "^7.4||^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "symfinity/ui-kernel": "^0.1",
        "symfony/browser-kit": "^7.4||^8.0",
        "symfony/css-selector": "^7.4||^8.0",
        "symfony/form": "^7.4||^8.0",
        "symfony/validator": "^7.4||^8.0"
    },
    "autoload": {
        "psr-4": {
            "Symfinity\\UxBlocksForm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfinity\\UxBlocksForm\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=512M"
    },
    "suggest": {
        "symfinity/form-ui-extensions-bundle": "Optional Symfony Form bridge for FormView vars and field widgets"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "symfony": {
            "require": "^7.4||^8.0"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
