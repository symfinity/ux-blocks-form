{% set itemAppearance = appearance != '' ? appearance : 'control' %}
{% if itemAppearance == 'button' %}
<input
    type="radio"
    id="{{ id }}"
    data-ui-role="radio"
    data-ui-appearance="button"
    data-ui-variant="{{ semantic_variant }}"
    data-ui-fragment="blocks.radio-group.item"
    name="{{ name }}"
    value="{{ value }}"
    {% if checked %}checked{% endif %}
    {% if disabled %}disabled data-ui-state="disabled"{% endif %}
/>
<label
    for="{{ id }}"
    data-ui-role="button"
    data-ui-variant="{{ semantic_variant }}"
    data-ui-appearance="{{ label_button_style }}"
    data-ui-size="{{ size }}"
    {% if disabled %}data-ui-state="disabled"{% endif %}
>
    <span data-ui-part="label">{{ label }}</span>
</label>
{% else %}
<label
    data-ui-role="radio-group-item"
    {{ attributes }}
>
    <input
        data-ui-role="radio"
        data-ui-fragment="blocks.radio-group.item"
        type="radio"
        name="{{ name }}"
        value="{{ value }}"
        {% if checked %}checked{% endif %}
        {% if disabled %}disabled data-ui-state="disabled"{% endif %}
    />
    {% block content %}{% endblock %}
</label>
{% endif %}
