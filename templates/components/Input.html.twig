{% if resolved_input_icon %}
<span
    data-ui-part="input-adornment"
    data-ui-icon-position="{{ input_icon_position }}"
>
    {% if input_icon_position == 'start' %}
        {% include '@UxBlocksCore/components/_shared/p_icon_slot.html.twig' with {
            iconName: resolved_input_icon,
            iconDecorative: iconDecorative,
        } only %}
    {% endif %}
    <input
        {% if variant %}data-ui-variant="{{ variant }}"{% endif %}
        {% if value %}value="{{ value }}"{% endif %}
        {% if placeholder %}placeholder="{{ placeholder }}"{% endif %}
        {% if invalid %}aria-invalid="true"{% endif %}
        {% if disabled %}disabled data-ui-state="disabled"{% elseif invalid %}data-ui-state="invalid"{% endif %}
        {{ attributes.without('type', 'class', 'id', 'style') }}
        type="{{ type }}"
    />
    {% if input_icon_position == 'end' %}
        {% include '@UxBlocksCore/components/_shared/p_icon_slot.html.twig' with {
            iconName: resolved_input_icon,
            iconDecorative: iconDecorative,
        } only %}
    {% endif %}
</span>
{% else %}
<input
    {% if variant %}data-ui-variant="{{ variant }}"{% endif %}
    {% if value %}value="{{ value }}"{% endif %}
    {% if placeholder %}placeholder="{{ placeholder }}"{% endif %}
    {% if invalid %}aria-invalid="true"{% endif %}
    {% if disabled %}disabled data-ui-state="disabled"{% elseif invalid %}data-ui-state="invalid"{% endif %}
    {{ attributes.without('type') }}
    type="{{ type }}"
/>
{% endif %}
